# Aegis Configuration
# Copy this file to .env and fill in your values

# ─── Application ──────────────────────────────────────────────────────────────
AEGIS_ENV=development
AEGIS_DEBUG=false
AEGIS_SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
AEGIS_API_HOST=0.0.0.0
AEGIS_API_PORT=8000
AEGIS_LOG_LEVEL=INFO

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ─── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
BULLMQ_QUEUE_NAME=aegis-scan

# ─── OpenAI (for CrewAI agents) ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ─── Mem0 ─────────────────────────────────────────────────────────────────────
MEM0_API_KEY=your-mem0-api-key
# Optional: use local Qdrant instead of Mem0 cloud
# MEM0_QDRANT_HOST=localhost
# MEM0_QDRANT_PORT=6333

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Requests per minute per API key by tier
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=100
RATE_LIMIT_ENTERPRISE=1000

# ─── File Processing ──────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
PROCESSING_TIMEOUT_SECONDS=30

# ─── Webhooks ─────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=your-webhook-signing-secret
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_SECONDS=60

# ─── Sentence Transformers ────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_TTL=3600
