# Aegis Guard - Self-Hosted Configuration
# Copy this file to .env and customize for your environment

# ─── Core Application ───────────────────────────────────────────────────────────
AEGIS_ENV=development
AEGIS_DEBUG=false
AEGIS_SECRET_KEY=change-me-in-production-min-32-chars
AEGIS_API_HOST=0.0.0.0
AEGIS_API_PORT=8000
AEGIS_LOG_LEVEL=INFO

# ─── Classifier Configuration ───────────────────────────────────────────────────
# Backend: "aegis" (PyTorch ML) or "rule" (rule-based)
CLASSIFIER_BACKEND=rule
CLASSIFIER_MODEL_PATH=/app/models/aegis_classifier.pt
CLASSIFIER_DEVICE=auto  # auto, cpu, cuda

# ─── Local LLM (Ollama) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=30

# Pull required models after starting Ollama:
#   ollama pull llama2
#   ollama pull all-minilm  # For embeddings

# ─── Supabase (Database) ────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Redis (Queue & Cache) ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ─── BullMQ (Job Queue) ─────────────────────────────────────────────────────────
BULLMQ_QUEUE_NAME=aegis-scan

# ─── Mem0 (Agent Memory) ────────────────────────────────────────────────────────
# Choose one: Qdrant OR Supabase (recommended: Supabase for self-hosted)
MEM0_USE_SUPABASE=true
MEM0_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Qdrant alternative (uncomment to use instead of Supabase)
# MEM0_QDRANT_HOST=localhost
# MEM0_QDRANT_PORT=6333

# ─── Langfuse (Telemetry - Optional) ────────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ─── Rate Limits ────────────────────────────────────────────────────────────────
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=100
RATE_LIMIT_ENTERPRISE=1000

# ─── Processing Limits ──────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
PROCESSING_TIMEOUT_SECONDS=30
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_TTL=3600

# ─── Webhooks ───────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=webhook-signing-secret-min-32-chars
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_SECONDS=60

# ─── Langfuse Self-Hosted (Optional) ────────────────────────────────────────────
# Uncomment to run Langfuse locally
# LANGFUSE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langfuse
# LANGFUSE_NEXTAUTH_SECRET=changeme
# LANGFUSE_NEXTAUTH_URL=http://localhost:3000
# LANGFUSE_SALT=changeme
# POSTGRES_PASSWORD=postgres
